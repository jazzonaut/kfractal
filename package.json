{
  "name": "kfractal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "oxfmt src tests vite.config.ts vitest.config.ts",
    "format:check": "oxfmt --check src tests vite.config.ts vitest.config.ts"
  },
  "dependencies": {
    "@primeuix/themes": "2.0.3",
    "@vueuse/core": "14.3.0",
    "primeicons": "7.0.0",
    "primevue": "4.5.5",
    "three": "0.184.0",
    "vue": "3.5.35",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/three": "0.184.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@webgpu/types": "0.1.70",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "playwright": "1.60.0",
    "pngjs": "7.0.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-primeui": "0.6.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.4"
  }
}
